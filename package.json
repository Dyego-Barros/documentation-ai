{
  "name": "Tools-AI",
  "displayName": "Tools AI",
  "description": "Gera documentação de classes e metodos em Python, C#, Java, JavaScript e Go e Dockerfiles e Docker Compose com auxilio de IA",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:docstring.generate",
    "onCommand:dockerfile.generate"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docstring.generate",
        "title": "Documentar código com IA"
      },
      {
        "command": "dockerfile.generate",
        "title": "Gerar Dockerfile + Compose com IA"
      }
    ]
  }
}